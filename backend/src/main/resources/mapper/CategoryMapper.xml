        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lilac.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.lilac.domain.entity.Category">
            <id property="id" column="id" />
